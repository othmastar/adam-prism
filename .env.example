# ═══════════════════════════════════════════════════════════════
# Adam Prism — Environment Variables — متغيرات البيئة
# ═══════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env

# ─── الأساسية — يجب تغييرها قبل الإنتاج ───
# مفتاح API — غيّره من القيمة الافتراضية!
ADAM_API_KEY=change-me-in-production
# مفتاح المسؤول — للعمليات الحساسة (إضافة MCP، تغيير إعدادات)
ADAM_ADMIN_KEY=admin-change-me

# ─── بيئة التشغيل ───
# development | staging | production
ADAM_ENVIRONMENT=development
# في وضع الإنتاج: الصلاحيات تصبح أكثر صرامة تلقائياً
ADAM_PRODUCTION=0

# ─── خادم API ───
API_HOST=0.0.0.0
API_PORT=8000

# ─── مزود النموذج (Inference) ───
# ollama | lora | openai | anthropic
INFERENCE_MODE=ollama
OLLAMA_BASE=http://localhost:11434
MODEL_NAME=adam-prism-v13:latest

# ─── LoRA Server ───
LORA_SERVER_URL=http://localhost:7861

# ─── Qdrant (قاعدة البيانات الشعاعية) ───
QDRANT_URL=http://localhost:6333

# ─── Embedding Model ───
EMBEDDING_MODEL=nomic-embed-text

# ─── OpenAI (لو تستخدمه) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Anthropic (لو تستخدمه) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── الأمان والحدود ───
# الحد الأقصى لعدد خوادم MCP
ADAM_MAX_MCP_SERVERS=10
# الحد الأقصى لعدد الوكلاء الفرعيين
ADAM_MAX_SUBAGENTS=10
# مهلة خمول الوكلاء الفرعيين (بالثواني)
ADAM_SUBAGENT_IDLE_TIMEOUT=3600

# ─── سجل الصلاحيات ───
# المسار الافتراضي: ~/.adam_prism/logs/
ADAM_PERMISSIONS_DIR=
# المسار الافتراضي: ~/.adam_prism/logs/permissions.jsonl
ADAM_PERMISSION_LOG=

# ─── Rate Limiting ───
ADAM_RATE_LIMIT_ENABLED=true

# ─── Audit Logging ───
ADAM_AUDIT_LOGGING_ENABLED=true
ADAM_AUDIT_DIR=

# ─── Observability ───
ADAM_TRACE_DIR=
ADAM_OTEL_ENABLED=false

# ─── Docker Sandbox ───
ADAM_SANDBOX_ENABLED=false

# ─── القنوات ───
# Telegram
TELEGRAM_BOT_TOKEN=
# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Discord
DISCORD_BOT_TOKEN=

# ─── الصوت ───
TTS_BACKEND=edge_tts
TTS_DIALECT=eg
TTS_VOICE=ar-EG-ShakirNeural

# ─── المتصفح ───
PLAYWRIGHT_BROWSERS_PATH=~/.local/ms-playwright

# ─── مسارات البيانات ───
ADAM_WORKSPACE=
ADAM_NOTEBOOK_DIR=
