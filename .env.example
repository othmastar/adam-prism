# ═══════════════════════════════════════════════════
# Adam Prism — متغيرات البيئة
# Environment Variables
# ═══════════════════════════════════════════════════
#
# انسخ هذا الملف إلى .env وعدّل القيم:
# cp .env.example .env
#
# ⚠️ مهم: لا ترفع ملف .env إلى الريبو!
# ═══════════════════════════════════════════════════

# ─── الأمان (مطلوب في الإنتاج) ───────────────────────

# مفتاح API — يجب تغييره قبل التشغيل!
# استخدم: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADAM_API_KEY=adam-prism-change-me

# مفتاح المسؤول — لإضافة خوادم MCP والعمليات الحساسة
# ⚠️ مطلوب في وضع الإنتاج!
ADAM_ADMIN_KEY=

# وضع الإنتاج — يفعّل كل الحمايات
# 0 = تطوير (أقل حماية)، 1 = إنتاج (حماية كاملة)
ADAM_PRODUCTION=0

# ─── الحدود ──────────────────────────────────────────

# الحد الأقصى لعدد الوكلاء الفرعيين
ADAM_MAX_SUBAGENTS=10

# الحد الأقصى لعدد خوادم MCP
ADAM_MAX_MCP_SERVERS=10

# الحد الأقصى لطلبات API في الدقيقة لكل IP
ADAM_RATE_LIMIT=60

# الحد الأقصى لحجم طلب API (بايت)
ADAM_MAX_REQUEST_SIZE=10485760

# مهلة خمول الوكلاء الفرعيين (ثواني) — 3600 = ساعة
ADAM_SUBAGENT_IDLE_TIMEOUT=3600

# ─── النموذج ─────────────────────────────────────────

# وضع الاستنتاج: ollama, openai, anthropic
INFERENCE_MODE=ollama

# اسم النموذج
MODEL_NAME=adam-prism-v13:latest

# عنوان Ollama
OLLAMA_BASE=http://localhost:11434

# عنوان Qdrant
QDRANT_URL=http://localhost:6333

# عنوان خادم LoRA
LORA_SERVER_URL=http://localhost:8080

# ─── الويب ───────────────────────────────────────────

# أصول CORS — * للسماح بالكل، أو قائمة مفصولة بفواصل
CORS_ORIGINS=*

# ─── التخزين ─────────────────────────────────────────

# مسار قاعدة بيانات الذاكرة
ADAM_MEMORY_DB=

# مسار ملف سجل الصلاحيات
ADAM_PERMISSION_LOG=/tmp/adam_permissions.log

# مسار مساحة العمل
ADAM_WORKSPACE=

# ─── المنصات (اختياري) ──────────────────────────────

# Discord Bot
DISCORD_TOKEN=
DISCORD_ENABLED=false

# Telegram Bot
TELEGRAM_TOKEN=
TELEGRAM_ENABLED=false

# WhatsApp
WHATSAPP_ENABLED=false
