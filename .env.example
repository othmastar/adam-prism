# ═══════════════════════════════════════════════════════════
# Adam Prism — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ─── Authentication (REQUIRED in production) ─────────────
# API key for all endpoints — MUST be changed from default
ADAM_API_KEY=adam-prism-change-me

# Admin key for sensitive operations (MCP, system config)
# REQUIRED in production mode
ADAM_ADMIN_KEY=

# ─── Production Mode ────────────────────────────────────
# Set to "1" to enforce strict security (requires API + Admin keys)
ADAM_PRODUCTION=0

# ─── AI Providers ───────────────────────────────────────
# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI / OpenRouter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LoRA Server (fine-tuned model)
LORA_SERVER_URL=http://localhost:8080

# ─── Vector Database ────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Embedding Model ────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text

# ─── Security & Limits ──────────────────────────────────
# Maximum concurrent subagents
ADAM_MAX_SUBAGENTS=10

# Maximum MCP servers
ADAM_MAX_MCP_SERVERS=10

# Subagent idle timeout in seconds (default: 1 hour)
ADAM_SUBAGENT_IDLE_TIMEOUT=3600

# API rate limit (requests per minute per IP)
ADAM_RATE_LIMIT=60

# Maximum request body size in bytes (default: 10MB)
ADAM_MAX_REQUEST_SIZE=10485760

# Permission log path
ADAM_PERMISSION_LOG=/tmp/adam_permissions.log

# Data directory for persistent storage
ADAM_DATA_DIR=~/.adam_prism

# ─── Channels ───────────────────────────────────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHATS=

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Discord Bot
DISCORD_BOT_TOKEN=
DISCORD_ENABLED=false

# ─── Voice Pipeline ─────────────────────────────────────
# VAD model (Silero)
VAD_MODEL=silero_vad

# ASR model (faster-whisper)
ASR_MODEL=base

# TTS voice
TTS_VOICE=default

# ─── CORS ───────────────────────────────────────────────
# Allowed origins (comma-separated, or * for all)
CORS_ORIGINS=*

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Docker Services ────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
