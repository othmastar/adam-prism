# [PHASE3] Test environment for CI
# Used by integration tests and any other tests that need a running API.
# This file is read by .github/workflows/ci.yml.

# Test API key (must match the one used in test fixtures)
ADAM_API_KEY=test-key-for-ci-only
ADAM_PRODUCTION=0

# Test database (in-memory SQLite)
ADAM_DATABASE_URL=sqlite:///:memory:

# Disable cache in tests
ADAM_REDIS_URL=

# Use a test model
ADAM_INFERENCE_MODE=ollama
ADAM_OLLAMA_BASE=http://localhost:11434
ADAM_QDRANT_URL=http://localhost:6333

# Logging
ADAM_LOG_LEVEL=WARNING
ADAM_LOG_JSON=0

# Server config
API_HOST=127.0.0.1
API_PORT=8000
