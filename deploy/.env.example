# Adam Prism — Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم

# ─── ضروري ────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_in_production

# [M15] Critical secrets that MUST be set before production
ADAM_API_KEY=change-me-in-production
ADAM_ADMIN_KEY=admin-change-me

# [M15] CORS origins — comma-separated list of allowed origins
# In production, do NOT use "*" — specify exact domains
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# [M15] Rate limiting configuration
# Format: max_requests/window_seconds (e.g., 60/60 = 60 requests per minute)
ADAM_RATE_LIMIT=60/60

# ─── اختياري ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
AUTHORIZED_CHAT_IDS=[]
