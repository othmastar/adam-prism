# Adam Prism — Web UI Environment Variables
# Copy this file to .env.local and adjust values

# ─── Required ────────────────────────────────
# API URL (where the backend is running)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (for streaming chat)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Optional ────────────────────────────────
# Application name
NEXT_PUBLIC_APP_NAME="Adam Prism"

# Enable/disable features
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=true
NEXT_PUBLIC_ENABLE_TELEMETRY=false

# Authentication (when implemented)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-me-to-random-string
