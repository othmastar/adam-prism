{
  "name": "adam-prism",
  "displayName": "Adam Prism",
  "description": "Your conscious AI digital twin — Egyptian Arabic AI assistant in VS Code",
  "version": "1.0.0",
  "publisher": "othmastar",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/othmastar/adam-prism"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "egyptian-arabic",
    "assistant",
    "code-review",
    "adam"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adam-prism.chat",
        "title": "آدم: Open Chat"
      },
      {
        "command": "adam-prism.explainCode",
        "title": "آدم: Explain Selected Code"
      },
      {
        "command": "adam-prism.reviewCode",
        "title": "آدم: Review Selected Code"
      },
      {
        "command": "adam-prism.debugCode",
        "title": "آدم: Debug Selected Code"
      },
      {
        "command": "adam-prism.writeTest",
        "title": "آدم: Write Test for Selected Code"
      },
      {
        "command": "adam-prism.askAboutFile",
        "title": "آدم: Ask About Current File"
      },
      {
        "command": "adam-prism.setEndpoint",
        "title": "آدم: Set API Endpoint"
      }
    ],
    "keybindings": [
      {
        "command": "adam-prism.chat",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "adam-prism.explainCode",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e"
      }
    ],
    "configuration": {
      "title": "Adam Prism",
      "properties": {
        "adam-prism.endpoint": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Adam Prism API endpoint URL"
        },
        "adam-prism.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional API key for authentication"
        },
        "adam-prism.language": {
          "type": "string",
          "default": "ar",
          "enum": ["ar", "en"],
          "enumDescriptions": ["Arabic (Egyptian)", "English"],
          "description": "Response language preference"
        },
        "adam-prism.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum response tokens"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "eslint": "^8.50.0"
  }
}
